{
  "manifest_version": 3,
  "name": "PromptPilot Starter",
  "version": "0.1.0",
  "description": "Read a focused prompt field, enhance it via your backend, preview it, and insert it back into the page.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "PromptPilot Starter",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
